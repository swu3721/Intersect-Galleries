# Copy to .env — values from Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Spotify track search (Edge Function `spotify-search` — not Vite env vars).
# Dashboard: Project Settings → Edge Functions → Manage secrets → SPOTIFY_CLIENT_ID, SPOTIFY_CLIENT_SECRET
# Local: copy supabase/functions/.env.example to supabase/functions/.env, then `supabase functions serve`
# Spotify app: https://developer.spotify.com/dashboard
